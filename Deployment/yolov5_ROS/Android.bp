
cc_binary {
    name: "yolov5",

    vendor: true,

    srcs: [
        "main.c",
        "yolov5_post_process.cpp",
        "yolov5_pre_process.cpp",
    ],

    shared_libs: [
        "libawnn.viplite",
        "liblog",
    ],

    static_libs: [
        "libawutils",
        "libopencv",
    ],

    required: [
        "yolov5.nb",
        "dog.jpg",
        "yolov5.sh",
    ],

}

sh_binary {
    name: "yolov5.sh",
    src: "yolov5.sh",
}
